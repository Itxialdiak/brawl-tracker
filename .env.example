# Copia este archivo a ".env" y rellena tus valores.

# Token de developer.brawlstars.com (un texto larguísimo tipo JWT).
BRAWL_API_TOKEN=

# Tu tag de jugador, con almohadilla. Ej: #2P0LYQQRJ
BRAWL_PLAYER_TAG=

# Cada cuántos segundos consultar el battlelog (180 = 3 min está bien).
POLL_INTERVAL_SECONDS=180

# --- PROXY DE ROYALEAPI (activo) ---------------------------------------------
# Estamos usando el proxy de RoyaleAPI para no depender de tu IP pública.
# Por eso en la KEY de Brawl Stars debes dar de alta la IP DEL PROXY (45.79.218.79),
# NO la tuya. Verifica la IP vigente en https://docs.royaleapi.com/proxy
BRAWL_API_BASE=https://proxy.royaleapi.dev/v1
#
# Cuando migres a un VPS con IP fija, comenta la línea de arriba (o ponla en
# https://api.brawlstars.com/v1) y da de alta la IP DEL VPS en la key.
# -----------------------------------------------------------------------------
